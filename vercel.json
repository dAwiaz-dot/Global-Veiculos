{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "*.html",
        "*.css",
        "*.js",
        "manifest.webmanifest",
        "assets/**",
        "data/**"
      ]
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/admin",
      "dest": "/api/index.js"
    },
    {
      "src": "/login",
      "dest": "/api/index.js"
    },
    {
      "src": "/admin.html",
      "dest": "/api/index.js"
    },
    {
      "src": "/admin-cadastro.html",
      "dest": "/api/index.js"
    },
    {
      "src": "/admin-financeiro.html",
      "dest": "/api/index.js"
    },
    {
      "src": "/admin-meta.html",
      "dest": "/api/index.js"
    },
    {
      "src": "/admin-publicacao.html",
      "dest": "/api/index.js"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "handle": "filesystem"
    }
  ]
}
