{
  "version": 2,
  "functions": {
    "server.js": {
      "includeFiles": [
        "*.html",
        "*.css",
        "*.js",
        "manifest.webmanifest",
        "assets/**",
        "data/**"
      ]
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
